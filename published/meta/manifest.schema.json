{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avejourneys.com/intelligence/meta/manifest.schema.json",
  "title": "Avé Intelligence artifact manifest",
  "type": "object",
  "required": ["schemaVersion", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string" },
    "generatedAt": { "type": ["string", "null"], "format": "date-time" },
    "gitSha": { "type": ["string", "null"] },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "version", "path"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "type": { "enum": ["series", "forecast", "report"] },
          "version": { "type": "integer", "minimum": 1 },
          "latest": { "type": "boolean" },
          "path": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "pdfUrl": { "type": "string", "format": "uri" },
          "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "createdAt": { "type": "string", "format": "date-time" },
          "metric": { "type": "string" },
          "geo": { "type": "string" },
          "model": { "type": "string" },
          "horizon": { "type": "string" },
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" }
        }
      }
    }
  }
}
